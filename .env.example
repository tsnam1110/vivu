# === Ứng dụng ===
APP_NAME=ViVu
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://vivu.test
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en

# === Log ===
LOG_CHANNEL=stack
LOG_LEVEL=debug

# === Cơ sở dữ liệu (MySQL 8) ===
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vivu
DB_USERNAME=root
DB_PASSWORD=

# === Session / Cache / Queue ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
# Khi scale: chuyển sang redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# === Sanctum (admin SPA) ===
# Domain public + origin dev của admin SPA (Vite)
SANCTUM_STATEFUL_DOMAINS=vivu.test,localhost:5173,127.0.0.1:5173

# === Filesystem ===
FILESYSTEM_DISK=public
# Khi production dùng S3:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=

# === Google Maps ===
# Key client (Maps JS + Places): giới hạn theo HTTP referrer (domain)
GOOGLE_MAPS_API_KEY=
# Key server (Geocoding server-side, tuỳ chọn): giới hạn theo IP server
GOOGLE_MAPS_SERVER_KEY=

# === Mail ===
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@vivu.test"
MAIL_FROM_NAME="${APP_NAME}"

# === Admin panel (đọc bởi Vite trong thư mục admin/) ===
# Đặt trong admin/.env, KHÔNG ở đây:
# VITE_API_BASE_URL=http://vivu.test/api
